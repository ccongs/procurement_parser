# 나라장터 입찰공고정보서비스 - 환경설정 템플릿 (커밋용)
# 실제 값은 .env 파일에 입력하세요. .env 는 커밋하지 않습니다.

# 공공데이터포털 발급 서비스 키 (디코딩 키 권장)
PROCUREMENT_SERVICE_KEY=

# API 베이스 URL
PROCUREMENT_BASE_URL=http://apis.data.go.kr/1230000/ad/BidPublicInfoService

# 기본 응답 타입 (xml 또는 json)
PROCUREMENT_RESPONSE_TYPE=json

# 로그 레벨 (기본 INFO; DEBUG·WARNING·ERROR 도 가능)
# LOG_LEVEL=INFO

# Phase 6 / 6.4 - RFP 분석 AI 프로바이더 설정
# ANALYSIS_PROVIDER: claude | openai | gemini (기본: claude)
ANALYSIS_PROVIDER=claude
# USE_ANALYSIS_PROVIDER: true면 RFP 분석 컬럼·버튼 표시, false면 숨김 (기본: false)
# AI 분석을 사용하지 않는 환경에서는 false(기본) 유지 — 분석 컬럼·버튼이 화면에서 숨겨진다.
USE_ANALYSIS_PROVIDER=false
# ANALYSIS_MODEL=  # 비워두면 provider 기본값 (claude-sonnet-4-6 / gpt-4o / gemini-1.5-pro)

# 프로바이더별 API 키 (사용할 프로바이더 키만 설정)
CLAUDE_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_google_gemini_api_key_here
# (기존 호환) ANTHROPIC_API_KEY=  # CLAUDE_API_KEY 없을 때 fallback
